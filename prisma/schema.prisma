generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearchPostgres"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgcrypto, uuid_ossp]
}

enum UserRole {
  USER
  ADMIN
}

enum OAuthProvider {
  GOOGLE
  TWITTER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}
