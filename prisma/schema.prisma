generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  income
  expense
}

enum UserRole {
  user
  admin
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  EXPIRED
}

enum PaymentMethod {
  BANK_TRANSFER
  EWALLET
  QRIS
  VIRTUAL_ACCOUNT
  CREDIT_CARD
}

enum WalletTransactionType {
  TOP_UP       
  PPOB         
  TRANSFER_IN  
  TRANSFER_OUT 
  WITHDRAWAL   
  REFUND       
}

enum WalletTransactionStatus {
  PENDING    
  PROCESSING 
  COMPLETED  
  FAILED     // Gagal
  CANCELLED  // Dibatalkan
  REFUNDED   // Di refund
}



model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                UserRole             @default(user)
  isActive            Boolean              @default(true) @map("is_active")
  lastLoginAt         DateTime?            @map("last_login_at")
  loginCount          Int                  @default(0) @map("login_count")
  walletBalance       Int                  @default(0) @map("wallet_balance")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  transactions        Transaction[]
  RefreshToken        RefreshToken[]
  Business            Business[]
  inventoryItems      InventoryItem[]
  paymentTransactions PaymentTransaction[]
  walletTransactions  WalletTransaction[]
  AuditLog            AuditLog[]

  aiUsages        AIUsage[]
  aiQuota         AIQuota?
  aiConversations AIConversation[]
  moduleReads     UserModuleRead[]
  dailyTips       UserDailyTip[]
  achievements    UserAchievement[]
  streak          UserStreak?

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  family    String
  isRevoked Boolean  @default(false) @map("is_revoked")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([family])
  @@map("refresh_tokens")
}

model Transaction {
  id           String          @id @default(cuid())
  userId       String
  amount       Int
  type         TransactionType
  category     String
  description  String
  txHash       String          @default("") @map("tx_hash")
  previousHash String?         @map("previous_hash")
  isVerified   Boolean         @default(true) @map("is_verified")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?       @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletTransaction WalletTransaction?


  @@index([userId, createdAt])
  @@index([txHash])
  @@index([deletedAt])
  @@map("transactions")
}

model Business {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  name        String
  type        String
  description String?
  address     String?
  phone       String?
  lat         Float? // Latitude
  lng         Float? // Longitude
  category    String? // Kategori bisnis 
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventoryItems       InventoryItem[]
  businessTransactions BusinessTransaction[]

  @@index([userId])
  @@map("businesses")
}

model BusinessTransaction {
  id              String          @id @default(cuid())
  businessId      String          @map("business_id")
  type            TransactionType // income | expense
  amount          Int // Dalam Rupiah
  category        String
  description     String
  transactionDate DateTime        @map("transaction_date") // Tanggal transaksi
  paymentMethod   String?         @map("payment_method") // Tunai, Transfer, QRIS, dll
  notes           String?         @db.Text // Catatan tambahan
  receiptUrl      String?         @map("receipt_url") // URL foto nota/bukti
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, transactionDate])
  @@index([businessId, type])
  @@map("business_transactions")
}

model InventoryItem {
  id         String    @id @default(cuid())
  businessId String    @map("business_id")
  userId     String    @map("user_id")
  name       String
  sku        String?
  quantity   Int       @default(0)
  unitPrice  Decimal   @map("unit_price") @db.Decimal(15, 2)
  costPrice  Decimal   @default(0) @map("cost_price") @db.Decimal(15, 2)
  unit       String    @default("pcs")
  minStock   Int       @default(0) @map("min_stock")
  maxStock   Int?      @map("max_stock")
  imageUrl   String?   @map("image_url")
  barcode    String?
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  User     User     @relation(fields: [userId], references: [id])

  @@index([businessId])
  @@index([sku])
  @@map("inventory_items")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  before    Json?
  after     Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model PaymentTransaction {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  externalId     String        @unique @map("external_id")
  idempotencyKey String?       @unique @map("idempotency_key")
  amount         Decimal       @db.Decimal(18, 2)
  currency       String        @default("IDR")
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  description    String?
  encryptedMeta  String?       @map("encrypted_meta")
  providerRef    String?       @map("provider_ref")
  webhookPayload Json?         @map("webhook_payload")
  failureReason  String?       @map("failure_reason")
  paidAt         DateTime?     @map("paid_at")
  expiresAt      DateTime?     @map("expires_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletTransaction WalletTransaction?

  @@index([userId])
  @@index([externalId])
  @@index([idempotencyKey])
  @@index([status])
  @@map("payment_transactions")
}

model AIUsage {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint     String
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  cost         Decimal  @default(0) @db.Decimal(10, 6)
  cached       Boolean  @default(false)
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, endpoint])
  @@index([createdAt])
  @@map("ai_usages")
}

model AIQuota {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthlyLimit  Int      @default(100)
  dailyLimit    Int      @default(20)
  usedThisMonth Int      @default(0)
  usedToday     Int      @default(0)
  monthResetAt  DateTime
  dailyResetAt  DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@map("ai_quotas")
}

model AIConversation {
  id        String                  @id @default(cuid())
  userId    String
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  context   String?                 @db.Text
  summary   String?                 @db.Text
  isActive  Boolean                 @default(true)
  messages  AIConversationMessage[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@index([userId])
  @@index([userId, isActive])
  @@map("ai_conversations")
}

model AIConversationMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String         @db.Text
  tokens         Int            @default(0)
  model          String?
  createdAt      DateTime       @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@map("ai_conversation_messages")
}

model LearningModule {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String?  @db.Text
  category     String
  difficulty   String   @default("beginner")
  content      String   @db.Text
  videoUrl     String?
  thumbnailUrl String?
  duration     Int      @default(0)
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reads UserModuleRead[]

  @@index([category])
  @@index([order])
  @@index([isActive])
  @@map("learning_modules")
}

model UserModuleRead {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId  String
  module    LearningModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  isRead    Boolean        @default(false)
  readAt    DateTime?
  createdAt DateTime       @default(now())

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([moduleId])
  @@map("user_module_reads")
}

model DailyTip {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  category  String
  createdAt DateTime @default(now())
  isActive  Boolean  @default(true)

  userTips UserDailyTip[]

  @@index([category, createdAt])
  @@map("daily_tips")
}

model UserDailyTip {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipId     String
  tip       DailyTip  @relation(fields: [tipId], references: [id], onDelete: Cascade)
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([userId, tipId])
  @@index([userId, createdAt])
  @@map("user_daily_tips")
}

model Terminology {
  id           String   @id @default(cuid())
  term         String   @unique
  slug         String   @unique
  definition   String   @db.Text
  category     String
  examples     Json?
  relatedTerms String[]
  createdAt    DateTime @default(now())

  @@index([category])
  @@map("terminologies")
}

model UserStreak {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastReadAt    DateTime?
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@map("user_streaks")
}

model Achievement {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  title       String
  description String   @db.Text
  icon        String?
  category    String
  requirement Json
  points      Int      @default(0)
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]

  @@index([category])
  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  earnedAt      DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@map("user_achievements")
}


model WalletTransaction {
  id                   String                  @id @default(cuid())
  userId               String                  @map("user_id")
  paymentTransactionId String?                 @unique @map("payment_transaction_id")
  transactionId        String                  @unique @map("transaction_id")
  type                 WalletTransactionType
  amount               Int
  balanceBefore        Int                     @map("balance_before")
  balanceAfter         Int                     @map("balance_after")
  status               WalletTransactionStatus @default(PENDING)
  description          String?
  referenceId          String?                 @map("reference_id")
  metadata             Json?
  recipientUserId      String?                 @map("recipient_user_id")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")
  deletedAt            DateTime?               @map("deleted_at")

  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentTransaction PaymentTransaction?   @relation(fields: [paymentTransactionId], references: [id], onDelete: SetNull)
  transaction        Transaction           @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, type])
  @@index([userId, status])
  @@index([paymentTransactionId])
  @@index([transactionId])
  @@index([referenceId])
  @@index([status, createdAt(sort: Desc)])
  @@index([deletedAt])
  @@map("wallet_transactions")
}